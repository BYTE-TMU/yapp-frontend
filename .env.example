# Backend API URL (local development uses port 5001)
VITE_API_URL=http://localhost:5001

# For production, set to your Railway/deployed backend URL:
# VITE_API_URL=https://yap-backend-production.up.railway.app

# LocationIQ API key for map tiles and reverse geocoding
# Sign up free at https://locationiq.com — 5,000 requests/day
# Add HTTP Referrer Restrictions on your token in the LocationIQ dashboard
VITE_LOCATIONIQ_API_KEY=your_locationiq_api_key_here

